# ============================================================
# Vedinc Website - Unified Environment Variables
# ------------------------------------------------------------
# Copy this file to `.env` and fill in.
# This single .env is shared by BOTH backend and frontend.
# ============================================================

# ----- App / Runtime -----
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:8080
APP_URL=http://localhost:8080

# ----- Supabase: API / Storage / DB -----
SUPABASE_URL="https://YOUR-REF.supabase.co"
# Service role secret. Server-side only - never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ----- Auth -----
JWT_SECRET="replace-me-with-a-long-random-string-at-least-32-chars"

# ----- Email (Nodemailer / Gmail SMTP). Leave blank if unused. -----
EMAIL_USER=
EMAIL_PASS=
ADMIN_EMAIL=

# ============================================================
# Frontend (Vite) - any var below MUST start with VITE_
# Vite reads this same file because envDir is set to the project root.
# ============================================================
VITE_API_URL=http://localhost:5000/api
